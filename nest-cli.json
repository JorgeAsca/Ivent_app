{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/ms-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false,
    "tsConfigPath": "tsconfig.json"
  },
  "monorepo": true,
  "root": ".",
  "projects": {
    "ms-gateway": {
      "type": "application",
      "root": "apps/ms-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/ms-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-gateway/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src"
    },
    "ms-administracion": {
      "type": "application",
      "root": "apps/ms-administracion",
      "entryFile": "main",
      "sourceRoot": "apps/ms-administracion/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-administracion/tsconfig.app.json"
      }
    },
    "ms-inventario": {
      "type": "application",
      "root": "apps/ms-inventario",
      "entryFile": "main",
      "sourceRoot": "apps/ms-inventario/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-inventario/tsconfig.app.json"
      }
    },
    "ms-usuarios": {
      "type": "application",
      "root": "apps/ms-usuarios",
      "entryFile": "main",
      "sourceRoot": "apps/ms-usuarios/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-usuarios/tsconfig.app.json"
      }
    },
    "ms-configuracion": {
      "type": "application",
      "root": "apps/ms-configuracion",
      "entryFile": "main",
      "sourceRoot": "apps/ms-configuracion/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-configuracion/tsconfig.app.json"
      }
    },
    "ms-analytics": {
      "type": "application",
      "root": "apps/ms-analytics",
      "entryFile": "main",
      "sourceRoot": "apps/ms-analytics/src",
      "compilerOptions": { "tsConfigPath": "apps/ms-analytics/tsconfig.app.json" }
    },
    "ms-ventas": {
      "type": "application",
      "root": "apps/ms-ventas",
      "entryFile": "main",
      "sourceRoot": "apps/ms-ventas/src",
      "compilerOptions": { "tsConfigPath": "apps/ms-ventas/tsconfig.app.json" }
    },
    "ms-logistica": {
      "type": "application",
      "root": "apps/ms-logistica",
      "entryFile": "main",
      "sourceRoot": "apps/ms-logistica/src",
      "compilerOptions": { "tsConfigPath": "apps/ms-logistica/tsconfig.app.json" }
    },
    "ms-terceros": {
      "type": "application",
      "root": "apps/ms-terceros",
      "entryFile": "main",
      "sourceRoot": "apps/ms-terceros/src",
      "compilerOptions": { "tsConfigPath": "apps/ms-terceros/tsconfig.app.json" }
    }
  }
}